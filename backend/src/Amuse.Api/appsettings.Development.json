{
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:3001",
      "http://127.0.0.1:3000",
      "http://127.0.0.1:3001"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=amuse_development;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "amuse",
    "Audience": "amuse-api",
    "SigningKey": "DEV_ONLY_CHANGE_ME_32_CHARS_MINIMUM_KEY",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 14
  },
  "ExternalProviders": {
    "Providers": {}
  },
  "Identity:Email": {
    "RequireConfirmation": true,
    "ConsumerAppBaseUrl": "http://localhost:3000",
    "BusinessAppBaseUrl": "http://localhost:3001",
    "ConfirmationTokenHours": 24,
    "ResendCooldownSeconds": 60,
    "Smtp": {
      "Enabled": true,
      "Host": "localhost",
      "Port": 1025,
      "UseSsl": false,
      "FromAddress": "noreply@amuse.local",
      "FromName": "Amuse"
    }
  },
  "Tenancy": {
    "BusinessPortalBaseUrl": "http://localhost:3001"
  },
  "Platform": {
    "Root": {
      "AccountId": "00000000-0000-7000-8000-000000000001",
      "Email": "root@amuse.local",
      "Password": "ChangeMe_Root123!",
      "Claims": []
    }
  },
  "Media": {
    "Endpoint": "http://localhost:9000",
    "PublicBaseUrl": "http://localhost:9000",
    "AccessKey": "amuse",
    "SecretKey": "amuse_dev_secret",
    "ForcePathStyle": true,
    "CoversBucket": "amuse-covers",
    "AudioBucket": "amuse-audio",
    "SignedUrlMinutes": 30
  },
  "Redis": {
    "ConnectionString": "localhost:6379,password=amuse_dev_secret,abortConnect=false",
    "BlacklistKeyPrefix": "amuse:identity:blacklist:",
    "RevokedChannel": "amuse:identity:token-revoked"
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "amuse",
    "Password": "amuse_dev_secret",
    "QueueName": "amuse.transcode.jobs",
    "PrefetchCount": 1
  },
  "Billing": {
    "PlatformFee": {
      "DefaultRateBps": 1000
    },
    "Tax": {
      "DefaultVatBps": 1000,
      "PricesTaxInclusive": true
    },
    "Hold": {
      "Days": 3
    },
    "WithdrawalAutoApprove": {
      "MaxAutoApproveUsdMinor": 500000,
      "CooldownDays": 7
    },
    "Stripe": {
      "SecretKey": "",
      "WebhookSecret": "",
      "PublishableKey": ""
    },
    "Checkout": {
      "SuccessUrl": "http://localhost:3000/library/purchases?checkout=success",
      "CancelUrl": "http://localhost:3000/library/purchases?checkout=cancelled"
    },
    "GlobalPayout": {
      "AccountLinkReturnUrl": "http://localhost:3001/finance/payout-setup?stripe=return",
      "AccountLinkRefreshUrl": "http://localhost:3001/finance/payout-setup?stripe=refresh"
    },
    "FxRateImport": {
      "EcbDailyUrl": "https://www.ecb.europa.eu/stats/eurofxref/eurofxref-daily.xml",
      "RunIntervalHours": 24,
      "SupportedQuoteCurrencies": ["VND", "EUR", "GBP"]
    }
  },
  "BillingScheduler": {
    "PollIntervalSeconds": 300
  }
}
